{
  "name": "financial-presentation-writer-frontend",
  "version": "0.0.1",
  "private": true,
  "config": {
    "app_to_debug": "powerpoint",
    "app_type_to_debug": "desktop",
    "dev_server_port": 3010
  },
  "scripts": {
    "format": "prettier --write .",
    "build": "webpack --mode production",
    "build:dev": "webpack serve --mode development",
    "lint": "eslint src/**/*.{ts,tsx}",
    "lint:fix": "office-addin-lint fix",
    "prettier": "office-addin-lint prettier",
    "make-pretty": "prettier --write 'src/**/*.{ts,tsx}'",
    "start:desktop": "concurrently \"webpack serve --mode development\" \"office-addin-debugging start manifest_local.xml desktop\"",
    "start:web": "concurrently \"webpack serve --mode development\" \"office-addin-debugging start manifest_local.xml web\"",
    "stop": "office-addin-debugging stop manifest_local.xml",
    "validate": "office-addin-manifest validate manifest.xml",
    "watch": "webpack --mode development --watch"
  },
  "dependencies": {
    "@azure/msal-browser": "^3.20.0",
    "@azure/msal-react": "^2.0.22",
    "@fluentui/react-components": "^9.69.0",
    "@fluentui/react-icons": "^2.0.252",
    "@microsoft/office-js": "^1.1.93",
    "@reduxjs/toolkit": "^2.2.7",
    "@types/node": "^22.0.2",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/react-router-dom": "^5.3.3",
    "core-js": "^3.36.0",
    "css-loader": "^7.1.2",
    "date-fns": "^3.6.0",
    "dotenv": "^8.2.0",
    "i18next": "^23.12.2",
    "jszip": "^3.10.1",
    "jwt-decode": "^4.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-i18next": "^15.0.1",
    "react-redux": "^9.1.2",
    "react-router": "^6.26.0",
    "react-router-dom": "^6.26.0",
    "redux-persist": "^6.0.0",
    "regenerator-runtime": "^0.14.1",
    "style-loader": "^4.0.0",
    "toastr": "^2.1.4"
  },
  "devDependencies": {
    "@babel/core": "^7.24.9",
    "@babel/preset-env": "^7.25.2",
    "@babel/preset-react": "^7.24.7",
    "@babel/preset-typescript": "^7.24.7",
    "@types/office-js": "^1.0.407",
    "@types/office-runtime": "^1.0.35",
    "@types/toastr": "^2.1.43",
    "babel-loader": "^9.1.3",
    "concurrently": "^6.3.0",
    "copy-webpack-plugin": "^12.0.2",
    "css-minimizer-webpack-plugin": "^7.0.2",
    "dotenv-webpack": "^8.1.0",
    "html-loader": "^5.0.0",
    "html-webpack-plugin": "^5.6.0",
    "json-loader": "^0.5.7",
    "mini-css-extract-plugin": "^2.9.0",
    "office-addin-cli": "^2.0.3",
    "office-addin-debugging": "^6.0.3",
    "office-addin-dev-certs": "^2.0.3",
    "office-addin-lint": "^3.0.3",
    "office-addin-manifest": "^2.0.3",
    "prettier": "^3.3.3",
    "terser-webpack-plugin": "^5.3.10",
    "typescript": "^5.5.4",
    "webpack": "^5.95.0",
    "webpack-cli": "^5.1.4",
    "webpack-dev-server": "^5.0.4"
  }
}
